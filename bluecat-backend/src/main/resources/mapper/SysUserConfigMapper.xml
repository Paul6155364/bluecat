<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bluecat.mapper.SysUserConfigMapper">

    <!-- 根据用户ID查询授权的网吧配置ID列表 -->
    <select id="selectConfigIdsByUserId" resultType="java.lang.Long">
        SELECT config_id
        FROM sys_user_config
        WHERE user_id = #{userId}
    </select>

    <!-- 根据网吧配置ID删除所有关联 -->
    <delete id="deleteByConfigId">
        DELETE FROM sys_user_config
        WHERE config_id = #{configId}
    </delete>

</mapper>
